# GDI Env Configurations
VITE_GDI_ENV=production
VITE_GDI_PUBLIC_BASE_URL=
VITE_PORTAL_BOSS_BASE_URL=https://api.portalboss.com.br

# Google Real Public Auth
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# Google Service Credentials (Secure Server-Side variables)
GDI_GOOGLE_CLIENT_SECRET=
GDI_GOOGLE_SERVICE_ACCOUNT_EMAIL=
GDI_GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GDI_GOOGLE_PROJECT_ID=

# Scopes mapped for GDI operation
GDI_GOOGLE_DOCS_SCOPES=https://www.googleapis.com/auth/documents
GDI_GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.file

# Portal BOSS Integration Webhook Details
GDI_PORTAL_BOSS_WEBHOOK_URL=https://api.portalboss.com.br/gdi/webhook
GDI_PORTAL_BOSS_CALLBACK_SECRET=
GDI_INTEGRATION_KEY=gdi_key_portal_boss_connect_2026_secured
